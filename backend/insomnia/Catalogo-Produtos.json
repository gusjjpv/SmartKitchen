  "resources": [
    {
      "_id": "__WORKSPACE__",
      "_type": "workspace",
      "name": "SmartKitchen - Catalogo de Produtos",
      "scope": "collection",
      "description": "### Instrucoes de uso\n\n1. Execute os requests da pasta **Setup** em ordem para criar usuario e restaurante\n2. Copie os IDs retornados para as variaveis de ambiente (icone de olho no canto superior direito)\n3. Execute os requests de Categorias e Produtos normalmente"
    },
    {
      "_id": "__ENV__",
      "_type": "environment",
      "parentId": "__WORKSPACE__",
      "name": "Base Environment",
      "data": {
        "base_url": "http://localhost:3000",
        "usuario_id": "",
        "restaurante_id": "",
        "categoria_id": "",
        "produto_id": "",
        "outro_restaurante_id": "id-que-nao-existe"
      }
    },
    {
      "_id": "fld_setup",
      "_type": "request_group",
      "parentId": "__WORKSPACE__",
      "name": "Setup (criar dados base)",
      "description": "Execute em ordem para criar usuario e restaurante. Depois copie os IDs para as variaveis de ambiente."
    },
    {
      "_id": "fld_categorias",
      "_type": "request_group",
      "parentId": "__WORKSPACE__",
      "name": "Categorias",
      "description": "CRUD de categorias com escopo por restaurante"
    },
    {
      "_id": "fld_produtos",
      "_type": "request_group",
      "parentId": "__WORKSPACE__",
      "name": "Produtos",
      "description": "CRUD de produtos com escopo por restaurante e validacao de categoria"
    },
    {
      "_id": "fld_erros_cat",
      "_type": "request_group",
      "parentId": "fld_categorias",
      "name": "Erros (validacao)",
      "description": "Testes de erro para categorias"
    },
    {
      "_id": "fld_erros_prod",
      "_type": "request_group",
      "parentId": "fld_produtos",
      "name": "Erros (validacao)",
      "description": "Testes de erro para produtos"
    },
    {
      "_id": "req_setup_user",
      "_type": "request",
      "parentId": "fld_setup",
      "name": "1. Criar usuario",
      "method": "POST",
      "url": "{{ base_url }}/cadastro",
      "headers": [
        { "name": "Content-Type", "value": "application/json" }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"nome\": \"Admin Teste\",\n  \"email\": \"admin{{ $randomInt }}\",\n  \"senha\": \"123456\",\n  \"contato\": \"11999999999\"\n}"
      },
      "parameters": [],
      "description": "Resposta contem o id do usuario. Copie para a variavel {{ usuario_id }}"
    },
    {
      "_id": "req_setup_rest",
      "_type": "request",
      "parentId": "fld_setup",
      "name": "2. Criar restaurante",
      "method": "POST",
      "url": "{{ base_url }}/restaurantes",
      "headers": [
        { "name": "Content-Type", "value": "application/json" }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"admin_usuario_id\": \"{{ usuario_id }}\",\n  \"nome\": \"Meu Restaurante\",\n  \"slug\": \"meu-rest-{{ $randomInt }}\",\n  \"whatsapp\": \"11999999999\",\n  \"rua\": \"Rua A\",\n  \"numero\": \"123\",\n  \"bairro\": \"Centro\",\n  \"cidade\": \"Sao Paulo\"\n}"
      },
      "parameters": [],
      "description": "Resposta contem o id do restaurante. Copie para a variavel {{ restaurante_id }}"
    },
